# Server
HOST=127.0.0.1
PORT=5700
PUBLIC_BASE_URL=http://127.0.0.1:5700

# Stripe (test mode first)
# Get from https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_replace_me

# Stripe Price IDs for each plan
STRIPE_PRICE_STARTER=price_replace_starter
STRIPE_PRICE_PRO=price_replace_pro
STRIPE_PRICE_LIFETIME=price_replace_lifetime
# Comma-separated, e.g. card or card,link
STRIPE_PAYMENT_METHOD_TYPES=card

# Webhook signing secret from `stripe listen --forward-to ...`
STRIPE_WEBHOOK_SECRET=whsec_replace_me
# Optional: where Stripe Billing Portal sends users after they click return
STRIPE_PORTAL_RETURN_URL=http://127.0.0.1:5700/#pricing

# Delivery options
LICENSE_PREFIX=TOPFUN
DISCORD_INVITE_URL=https://discord.gg/NmSn7dqPC8
ENABLE_DEV_FULFILL=true
REVOKE_ON_CANCEL_AT_PERIOD_END=true
# Email delivery (Resend)
EMAIL_PROVIDER=resend
RESEND_API_KEY=re_replace_me
EMAIL_FROM=TopFun.gg <noreply@topfun.gg>
EMAIL_RESEND_COOLDOWN_SECONDS=30
# Loader download mode:
# - protected: email includes tokenized /api/download-loader link (recommended)
# - public: email uses LOADER_DOWNLOAD_URL directly
LOADER_DOWNLOAD_MODE=protected
LOADER_FILE_PATH=downloads/topfun-loader.exe
LOADER_FILE_NAME=topfun-loader.exe
# Only used in public mode:
LOADER_DOWNLOAD_URL=https://www.topfun.gg/downloads/topfun-loader.exe

# Loader launch token security
# Required for /api/loader-token and /api/loader-verify
LAUNCH_TOKEN_SECRET=replace_with_long_random_secret
LAUNCH_TOKEN_TTL_SECONDS=120
# Optional extra header gate for loader routes: x-loader-secret
LOADER_CLIENT_SECRET=

# KeyAuth automation (license provisioning + revoke on subscription delete)
KEYAUTH_SELLER_KEY=sellerkey_replace_me
# Optional: force seller endpoint host when one edge is blocked
KEYAUTH_SELLER_URL=https://keyauth.win/api/seller/
KEYAUTH_MASK=TOPFUN-*****
KEYAUTH_SUB_STARTER=starter
KEYAUTH_SUB_PRO=pro
KEYAUTH_SUB_LIFETIME=lifetime
# Number of separate keys generated per order (set to 1 if bulk generation is blocked)
KEYAUTH_KEYS_PRO=1
KEYAUTH_KEYS_LIFETIME=1
# Device-slot limits enforced by this backend (independent from number of generated keys)
DEVICE_SLOTS_STARTER=1
DEVICE_SLOTS_PRO=3
DEVICE_SLOTS_LIFETIME=2
KEYAUTH_DAYS_STARTER=7
KEYAUTH_DAYS_PRO=30
KEYAUTH_DAYS_LIFETIME=36500
